{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "maxNumberOfProblems": 10000,
  "ignorePaths": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "logs",
    "public",
    "reports",
    "mock",
    "**/*.min.js",
    "storybook-static",
    ".cache",
    ".claude",
    "CLAUDE.md",
    "_*.md"
  ],
  "words": [
    "eslintcache",
    "prettiercache",
    "tsbuildinfo",
    "iconify",
    "cspell",
    "BlaxBerry",
    "autodocs",
    "mozfullscreenchange",
    "webkitfullscreenchange",
    "WCAG",
    "SVGSVGElement",
    "rgba",
    "fullwidth",
    "Indexs"
  ]
}
